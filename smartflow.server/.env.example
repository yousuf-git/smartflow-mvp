# AWS IoT Core
AWS_IOT_ENDPOINT=xxxxxxxx-ats.iot.ap-south-1.amazonaws.com
AWS_IOT_PORT=8883
AWS_IOT_CLIENT_ID=smartflow-server-v1
AWS_IOT_CA_PATH=./certs/AmazonRootCA1.pem
AWS_IOT_CERT_PATH=./certs/server.cert.pem
AWS_IOT_KEY_PATH=./certs/server.private.key

# Database
DATABASE_URL=postgresql+asyncpg://smartflow:smartflow@localhost:5432/smartflow

# Plant / controller / taps (seeded on first boot)
PLANT_NAME=Demo Plant
CONTROLLER_NAME=DEV-001
TAPS=T1:Tap 1,T2:Tap 2

# Demo user (seeded on first boot)
DEMO_EMAIL=demo@smartflow.local
DEMO_FIRST_NAME=Demo
DEMO_LAST_NAME=User
DEMO_CUSTOMER_TYPE=normal
INITIAL_BALANCE=500

# Dispense
ACK_TIMEOUT_SECONDS=5
MAX_LITRES=100
IDLE_RELEASE_SECONDS=90
RETRY_LIMIT=3
RETRY_WINDOW_SECONDS=60

# HTTP
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Cloudinary
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...